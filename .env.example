# ── App ─────────────────────────────────────────
PORT=3001
APP_BASE_URL=http://localhost:3001

# ── OIDC ────────────────────────────────────────
OIDC_ISSUER=http://localhost:4000
OIDC_CLIENT_ID=checkbox-app
OIDC_CLIENT_SECRET=checkbox-app-secret

# ── OIDC Provider (run separately) ──────────────
OIDC_PORT=4000

# ── Redis ────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
